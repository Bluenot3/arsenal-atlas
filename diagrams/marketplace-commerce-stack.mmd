flowchart TD
  Build[Creator builds asset] --> AssetType{Asset type}
  AssetType --> Agent[Agent]
  AssetType --> Arsenal[Arsenal]
  AssetType --> PromptPack[Prompt Pack]
  AssetType --> Skill[Skill]
  AssetType --> Experience[Experience]
  Agent --> Review[Admin / quality review]
  Arsenal --> Review
  PromptPack --> Review
  Skill --> Review
  Experience --> Review
  Review --> Listing[Marketplace listing]
  Listing --> Discovery[Discover / search / category]
  Discovery --> Checkout[Checkout or gated install]
  Checkout --> Entitlement[Access grant / install / entitlement]
